<Window x:Class="SeatTooLong.App.Views.ReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        Title="统计报表" Width="700" Height="500"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Today Summary -->
        <GroupBox x:Name="GrpToday" Grid.Row="0" Header="今日概览" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Margin="10">
                <StackPanel Margin="0,0,30,0">
                    <TextBlock x:Name="LblTotalSitting" Text="总久坐时长" FontSize="11" Foreground="Gray"/>
                    <TextBlock x:Name="ValTotalSitting" Text="0h 0m" FontSize="20" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel Margin="0,0,30,0">
                    <TextBlock x:Name="LblStandCount" Text="起身次数" FontSize="11" Foreground="Gray"/>
                    <TextBlock x:Name="ValStandCount" Text="0" FontSize="20" FontWeight="Bold"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock x:Name="LblLongest" Text="最长连续久坐" FontSize="11" Foreground="Gray"/>
                    <TextBlock x:Name="ValLongest" Text="0m" FontSize="20" FontWeight="Bold"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <!-- Range selector -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="Btn7Days" Content="近7天" Click="Btn7Days_Click" Margin="0,0,8,0" Padding="12,4"/>
            <Button x:Name="Btn30Days" Content="近30天" Click="Btn30Days_Click" Padding="12,4"/>
        </StackPanel>

        <TextBlock x:Name="TxtRefreshHint" Grid.Row="2" Foreground="Gray" FontSize="12" Margin="0,0,0,8"
                   Text="每 5 秒刷新，包含当前正在进行的久坐"/>

        <!-- Chart -->
        <lvc:CartesianChart x:Name="Chart" Grid.Row="3"/>
    </Grid>
</Window>
