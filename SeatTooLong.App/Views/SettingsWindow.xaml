<Window x:Class="SeatTooLong.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Width="540" Height="540"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="170"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock x:Name="LblSitThreshold" Grid.Row="0" Text="久坐阈值（分钟）" VerticalAlignment="Center" Margin="0,8"/>
        <Grid Grid.Row="0" Grid.Column="1" Margin="0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="76"/>
            </Grid.ColumnDefinitions>
            <Slider x:Name="SliderSitThreshold" Minimum="15" Maximum="120"
                    TickFrequency="5" IsSnapToTickEnabled="True" Value="45"
                    ValueChanged="Slider_ValueChanged"/>
            <TextBlock x:Name="TxtSitThresholdValue" Grid.Column="1" Text="45 分钟"
                       VerticalAlignment="Center" TextAlignment="Right"/>
        </Grid>

        <TextBlock x:Name="LblRestDuration" Grid.Row="1" Text="休息时长（分钟）" VerticalAlignment="Center" Margin="0,8"/>
        <Grid Grid.Row="1" Grid.Column="1" Margin="0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="76"/>
            </Grid.ColumnDefinitions>
            <Slider x:Name="SliderRestDuration" Minimum="1" Maximum="15"
                    TickFrequency="1" IsSnapToTickEnabled="True" Value="5"
                    ValueChanged="Slider_ValueChanged"/>
            <TextBlock x:Name="TxtRestDurationValue" Grid.Column="1" Text="5 分钟"
                       VerticalAlignment="Center" TextAlignment="Right"/>
        </Grid>

        <TextBlock x:Name="LblInterval" Grid.Row="2" Text="检测间隔（秒）" VerticalAlignment="Center" Margin="0,8"/>
        <ComboBox x:Name="CmbInterval" Grid.Row="2" Grid.Column="1" Margin="0,8">
            <ComboBoxItem Content="1"/>
            <ComboBoxItem Content="2" IsSelected="True"/>
            <ComboBoxItem Content="3"/>
            <ComboBoxItem Content="5"/>
            <ComboBoxItem Content="10"/>
        </ComboBox>

        <TextBlock x:Name="LblAbsenceGracePeriod" Grid.Row="3" Text="离开宽限期（秒）" VerticalAlignment="Center" Margin="0,8"/>
        <Grid Grid.Row="3" Grid.Column="1" Margin="0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="76"/>
            </Grid.ColumnDefinitions>
            <Slider x:Name="SliderAbsenceGracePeriod" Minimum="1" Maximum="30"
                    TickFrequency="1" IsSnapToTickEnabled="True" Value="2"
                    ValueChanged="Slider_ValueChanged"/>
                <TextBlock x:Name="TxtAbsenceGracePeriodValue" Grid.Column="1" Text="2 秒"
                       VerticalAlignment="Center" TextAlignment="Right"/>
        </Grid>

        <TextBlock x:Name="LblCamera" Grid.Row="4" Text="摄像头" VerticalAlignment="Center" Margin="0,8"/>
        <ComboBox x:Name="CmbCamera" Grid.Row="4" Grid.Column="1" Margin="0,8"/>

        <TextBlock x:Name="LblAutoStart" Grid.Row="5" Text="开机自启" VerticalAlignment="Center" Margin="0,8"/>
        <CheckBox x:Name="ChkAutoStart" Grid.Row="5" Grid.Column="1" IsChecked="True" VerticalAlignment="Center" Margin="0,8"/>

        <TextBlock x:Name="LblLanguage" Grid.Row="6" Text="语言" VerticalAlignment="Center" Margin="0,8"/>
        <ComboBox x:Name="CmbLanguage" Grid.Row="6" Grid.Column="1" Margin="0,8">
            <ComboBoxItem x:Name="CmbLanguageAuto" Content="跟随系统" Tag="auto"/>
            <ComboBoxItem x:Name="CmbLanguageZh" Content="中文" Tag="zh"/>
            <ComboBoxItem x:Name="CmbLanguageEn" Content="English" Tag="en"/>
        </ComboBox>

        <TextBlock x:Name="LblOverlay" Grid.Row="7" Text="显示悬浮窗" VerticalAlignment="Center" Margin="0,8"/>
        <CheckBox x:Name="ChkOverlay" Grid.Row="7" Grid.Column="1" IsChecked="True" VerticalAlignment="Center" Margin="0,8"/>

        <TextBlock x:Name="LblOpacity" Grid.Row="8" Text="悬浮窗透明度" VerticalAlignment="Center" Margin="0,8"/>
        <Grid Grid.Row="8" Grid.Column="1" Margin="0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="76"/>
            </Grid.ColumnDefinitions>
            <Slider x:Name="SliderOpacity" Minimum="0.3" Maximum="1.0"
                    Value="0.8" TickFrequency="0.1" IsSnapToTickEnabled="True"
                    ValueChanged="Slider_ValueChanged"/>
            <TextBlock x:Name="TxtOpacityValue" Grid.Column="1" Text="80%"
                       VerticalAlignment="Center" TextAlignment="Right"/>
        </Grid>

        <TextBlock x:Name="TxtStatus" Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="2"
                   MinHeight="24" Foreground="#2E7D32" VerticalAlignment="Center"/>

        <StackPanel Grid.Row="11" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnReset" Content="重置默认值" MinWidth="110" Height="32" Margin="0,0,8,0" Click="BtnReset_Click"/>
            <Button x:Name="BtnApply" Content="应用" MinWidth="86" Height="32" Margin="0,0,8,0" Click="BtnApply_Click"/>
            <Button x:Name="BtnSave" Content="保存" MinWidth="86" Height="32" Click="BtnSave_Click"/>
        </StackPanel>
    </Grid>
</Window>
